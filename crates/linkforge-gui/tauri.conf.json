{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LinkForge",
  "version": "0.1.0",
  "identifier": "dev.linkforge.app",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LinkForge",
        "width": 1080,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
